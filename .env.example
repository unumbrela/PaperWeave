# PaperWeave 环境变量示例
# 复制为 .env.local 并填入真实值：cp .env.example .env.local
#
# 最小可运行：只需配置 DEEPSEEK_API_KEY，论文库会自动退化为纯本地 IndexedDB 模式。

# ── AI（论文分析与流式工具）──────────────────────────────
DEEPSEEK_API_KEY=                       # 默认 LLM，必填
DEEPSEEK_API_URL=https://api.deepseek.com/v1
OPENAI_API_KEY=                         # 可选，论文分析备选
GOOGLE_API_KEY=                         # 可选，论文分析备选（Gemini）
AI_PROVIDER=openai                      # openai | gemini（论文分析走哪家）

# ── 数据库与存储（论文库云端同步，可选）──────────────────
# 论文库以浏览器本地 Dexie(IndexedDB) 为「单一真相源」，默认纯本地即可完整使用。
# 仅当你需要跨设备同步时，才配置以下三项 + 打开 NEXT_PUBLIC_ENABLE_CLOUD_SYNC。
NEXT_PUBLIC_ENABLE_CLOUD_SYNC=false     # true 时，本地写操作会异步同步到云端（best-effort）
DATABASE_URL=                           # postgresql://user:pass@host:5432/db（Prisma）
NEXT_PUBLIC_SUPABASE_URL=               # Supabase 项目 URL（PDF 文件存储）
NEXT_PUBLIC_SUPABASE_ANON_KEY=          # Supabase anon key
