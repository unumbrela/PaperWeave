# PaperWeave 环境变量示例
# 复制为 .env.local 并填入真实值：cp .env.example .env.local
#
# 本地开发：配 DEEPSEEK_API_KEY 即可用上 AI；论文库为纯本地 IndexedDB，零配置。
#
# 公开部署（Vercel）：推荐【全部留空】——AI 走「访客自带 key」模式，访客在 /settings
# 填自己的 key，不花你的钱、不会被刷爆（见 DEPLOY.md）。检索 / 阅读 / 批注 / 可视化
# 不需要任何 key 也能用。若你想让 AI 默认可用并自付费，再在 Vercel 配 DEEPSEEK_API_KEY。

# ── AI（论文分析与流式工具）──────────────────────────────
DEEPSEEK_API_KEY=                       # 默认 LLM；本地填上，线上可留空（访客自带）
DEEPSEEK_API_URL=https://api.deepseek.com/v1
OPENAI_API_KEY=                         # 可选，论文分析备选
GOOGLE_API_KEY=                         # 可选，论文分析备选（Gemini）
AI_PROVIDER=openai                      # openai | gemini（论文分析走哪家）

# ── 登录 + 云端同步（可选，Supabase）─────────────────────
# 论文库默认纯本地 Dexie(IndexedDB)，零配置即可完整使用、登录入口隐藏。
# 配上以下两项即启用「登录 + 跨设备同步」（Auth + Postgres + RLS）。
# 详细设置见 AUTH-SETUP.md（建表 SQL、Google OAuth、回跳白名单等）。
NEXT_PUBLIC_SUPABASE_URL=               # https://<项目>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=          # anon public key（公开，受 RLS 保护）

# ── 旧版 Prisma 直连（可选，遗留）─────────────────────────
# 与上面的 Supabase 同步是两套独立方案；走 Supabase 即可，无需配下面这条。
DATABASE_URL=                           # postgresql://user:pass@host:5432/db（Prisma）
